<?xml version="1.0" encoding="UTF-8"?>
<config>
    <application title="SINP Hauts-de-France" mouseposition="false" logo="apps/commons/img/logo/logo-irpn.png" help="mviewer_help.html" measuretools="true" mapprint="true" exportpng="true" style="css/themes/sinp_hdf.css" togglealllayersfromtheme="true"/>
    <mapoptions maxzoom="19" projection="EPSG:2154" center="700000,7000000" zoom="9" projextent="-20037508.342789244, -20037508.342789244, 20037508.342789244, 20037508.342789244" />

    <baselayers style="gallery">
        <baselayer  type="WMS" id="osm" label="OpenStreetMap" title="Plan OSM Géobretagne" thumbgallery="img/basemap/osm.png"
            url="https://osm.geo2france.fr/mapcache/" layers="naturaliste" format="image/png" visible="true"
            attribution="GéoBretagne. Données : les contributeurs d'&lt;a href='https://www.openstreetmap.org/' target='_blank'>OpenStreetMap &lt;/a>,  &lt;a href='https://www.openstreetmap.org/copyright' target='_blank'>ODbL &lt;/a>" />
    </baselayers>
    <proxy url=""/>
    <searchparameters bbox="false" localities="true" features="false" />
	<extensions>
    	<extension type="component" id="filter" path="demo/addons"/>
	</extensions>
    <themes>
        <theme name="Synthèse par communes"  collapsed="false" id="vm_referentiel_communes_hdf" icon="fas fa-users">
			<layer id="vm_referentiel_communes_hdf" visible="true" tiled="true"
				searchable="false" queryable="true"
				name="Référentiel des communes" opacity="50"
                infopanel="right-panel" infoformat="application/vnd.ogc.gml" featurecount="20"
				url="http://localhost:8080/geoserver/sinp_hdf_dev/wms?service=WFS">
				<template url="/apps/sinp_hdf/templates/commune_detail_light.mst"></template>
			</layer>
            <layer id="synthese_evt_par_date_et_commune" visible="true" 
				name="Synthese Observations par communes" searchable="true" queryable="false"
				type="customlayer"	opacity="100" tooltip="true" tooltipcontent="{{libelle_commune}} &lt;br/&gt; Nb Observations : {{nb_observations}} &lt;br/&gt; Dernière observation : {{derniere_obs_date}}"
				url="apps/sinp_hdf/customlayers/synthese_obs_par_commune.js">
			</layer>
		</theme>
    </themes>
</config>