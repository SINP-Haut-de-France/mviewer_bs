<?xml version="1.0" encoding="UTF-8"?>
<config>
    <application title="Mviewer" mouseposition="false" logo="" help="mviewer_help.html" measuretools="true" mapprint="true" exportpng="true" style="css/themes/wet_asphalt.css" togglealllayersfromtheme="true"/>
    <mapoptions maxzoom="19" projection="EPSG:2154" center="700000,7000000" zoom="9" projextent="-20037508.342789244, -20037508.342789244, 20037508.342789244, 20037508.342789244" />

    <baselayers style="gallery">
        <baselayer  type="WMS" id="osm" label="OpenStreetMap" title="Plan OSM Géobretagne" thumbgallery="img/basemap/osm.png"
            url="https://osm.geo2france.fr/mapcache/" layers="naturaliste" format="image/png" visible="true"
            attribution="GéoBretagne. Données : les contributeurs d'&lt;a href='https://www.openstreetmap.org/' target='_blank'>OpenStreetMap &lt;/a>,  &lt;a href='https://www.openstreetmap.org/copyright' target='_blank'>ODbL &lt;/a>" />
    </baselayers>
    <proxy url=""/>
    <searchparameters bbox="false" localities="true" features="false" />
    <themes>
        <theme name="Synthèse par communes"  collapsed="false" id="mat_synthese_obs_par_commune_full_tooltip" icon="fas fa-users">
			<layer id="mat_synthese_obs_par_commune_full_tooltip" visible="false" tiled="false"
				searchable="false" queryable="true"
				name="Détail des observations par communes" opacity="50"
                infopanel="right-panel" infoformat="application/vnd.ogc.gml" featurecount="20"
				url="http://localhost:8080/geoserver/sinp_test_dev/wms?service=WMS">
			</layer>
            <layer id="obs_par_commune" showintoc="false"
				name="Synthese Observations par communes"
				visible="true"
				type="customlayer"
				opacity="1" tooltip="true" tooltipcontent="Commune : {{nom_commune}}&lt;/br&gt;Nombre d&apos;observations : {{nb_observations}}&lt;/br&gt;Nombre espèces observées :{{nb_especes_distinctes}}&lt;/br&gt;Nombre d&apos;observateurs : {{nb_observateurs}}"
				url="apps/sinp_hdf/customlayers/synthese_obs_par_commune.js">
			</layer>
		</theme>
    </themes>

</config>