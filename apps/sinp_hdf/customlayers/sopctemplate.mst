
{{#features}}
  <li id="{{feature_ol_uid}}" class="item" style="width:238px;">
      <ul>
        {{#fields_kv}}
          <li>{{key}} : {{value}}</li>
        {{/fields_kv}}
      </ul>
  </li>
  {{#details}}
  <li>
    <ul>
        Nom vernaculaire : {{nom_vern}}
    </ul>
  </li>
  {{/details}}
{{/features}}