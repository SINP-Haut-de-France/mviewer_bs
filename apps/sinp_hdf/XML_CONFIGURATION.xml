<!--
=============================================================================
CONFIGURATION XML - CHARGEMENT DES NOUVEAUX LAYERS
=============================================================================
À ajouter dans votre fichier XML de configuration (sinp_hdf.xml ou équivalent)

IMPORTANT: Charger SinpBaseLayer AVANT les autres customlayers!
=============================================================================
-->

<!-- ===== SECTION 1: CHARGER LA CLASSE ABSTRAITE (OBLIGATOIRE) ===== -->
<extensions>
  <!--
    ⭐ CHARGER EN PREMIER - C'est la classe de base pour tous les layers
    Tous les autres customlayers en dépendent!
  -->
  <extension type="javascript" src="apps/sinp_hdf/customlayers/SinpBaseLayer.js" />

  <!-- Charger les layers qui l'utilisent -->
  <extension type="javascript" src="apps/sinp_hdf/customlayers/communeSearch.js" />
  <extension type="javascript" src="apps/sinp_hdf/customlayers/grid5x5search.js" />
  <extension type="javascript" src="apps/sinp_hdf/customlayers/gridSearch10x10.js" />

  <!-- Autres layers existants (inchangés) -->
  <extension type="javascript" src="apps/sinp_hdf/customlayers/grid5x5search.js" />
  <extension type="javascript" src="apps/sinp_hdf/customlayers/grid10x10search.js" />
</extensions>

<!-- ===== SECTION 2: AJOUTER LES LAYERS DANS LE THEME ===== -->
<themes mini="true" legendmini="false">
  <theme name="Recherches" collapsed="false" id="searches" icon="fas fa-search">

    <!-- LAYER 1: Recherche avancée communes (REFACTORISÉ) -->
    <layer id="advancedSearch"
           name="Recherche avancée - Communes"
           visible="true"
           queryable="true"
           type="customlayer"
           opacity="0.8"
           legendurl="img/blank.gif"
           url="apps/sinp_hdf/customlayers/communeSearch.js"
           customcontrol="true"
           customcontrolpath="apps/sinp_hdf/customcontrols/advancedSearch"
           expanded="true"
           fields="geo_commune"
           tooltip="true"
           tooltipenabled="true"
           tooltipcontent="Commune: {{commune_name}} - Observations: {{nb_observations}}"
           nohighlight="false"
           metadata=""
           metadata-csw="">
    </layer>

    <!-- LAYER 2: Recherche grille 5x5 (NOUVEAU) -->
    <layer id="gridSearch5x5"
           name="Recherche - Grille 5x5"
           visible="false"
           queryable="true"
           type="customlayer"
           opacity="0.8"
           legendurl="img/blank.gif"
           url="apps/sinp_hdf/customlayers/grid5x5search.js"
           customcontrol="true"
           customcontrolpath="apps/sinp_hdf/customcontrols/advancedSearch"
           expanded="false"
           fields="geo_grille"
           tooltip="true"
           tooltipenabled="true"
           tooltipcontent="Grille 5x5 - Observations: {{nb_observations}}"
           nohighlight="false"
           metadata=""
           metadata-csw="">
    </layer>

    <!-- LAYER 3: Recherche grille 10x10 (NOUVEAU) -->
    <layer id="gridSearch10x10"
           name="Recherche - Grille 10x10"
           visible="false"
           queryable="true"
           type="customlayer"
           opacity="0.8"
           legendurl="img/blank.gif"
           url="apps/sinp_hdf/customlayers/gridSearch10x10.js"
           customcontrol="true"
           customcontrolpath="apps/sinp_hdf/customcontrols/advancedSearch"
           expanded="false"
           fields="geo_grille"
           tooltip="true"
           tooltipenabled="true"
           tooltipcontent="Grille 10x10 - Observations: {{nb_observations}}"
           nohighlight="false"
           metadata=""
           metadata-csw="">
    </layer>

    <!-- Autres layers existants (inchangés) -->
    <layer id="communeSearch"
           name="Recherche commune"
           ... />

    <layer id="especeSearch"
           name="Recherche espèce"
           ... />

  </theme>
</themes>

<!--
=============================================================================
NOTES IMPORTANTES
=============================================================================

1. ORDRE DE CHARGEMENT
   ✅ SinpBaseLayer doit être chargé EN PREMIER
   ✅ Les autres layers dépendent de SinpBaseLayer
   ✅ Ne pas changer l'ordre!

2. CUSTOMCONTROL
   ✅ Tous les nouveaux layers utilisent le même contrôle:
      customcontrolpath="apps/sinp_hdf/customcontrols/communeSearch"
   ✅ Le contrôle ouvre un modal React qui envoie les paramètres

3. LAYER IDS
   ✅ communeSearch   - Communes (refactorisé)
   ✅ gridSearch5x5    - Grille 5x5 (nouveau)
   ✅ gridSearch10x10  - Grille 10x10 (nouveau)

4. VISIBILITY
   ✅ communeSearch: visible="true" (défaut actif)
   ✅ gridSearch5x5: visible="false" (inactif par défaut)
   ✅ gridSearch10x10: visible="false" (inactif par défaut)
   → L'utilisateur peut les activer via l'interface

5. VIEWPARAMS AUTOMATIQUES
   ✅ Chaque layer utilise automatiquement:
      DATE_DEB, DATE_FIN, CD_REF, GRP_IDS
   ✅ Pas besoin de configuration supplémentaire
   ✅ Tout se passe via sinpQueryBuilder

6. CHAMPS AFFICHÉS
   ✅ fields="geo_commune" pour communes
   ✅ fields="geo_grille" pour grilles
   ✅ À adapter si nom de colonne différent

7. TOOLTIPS
   ✅ tooltipenabled="true" pour afficher au survol
   ✅ tooltipcontent personnalisé pour chaque layer

=============================================================================
-->

<!--
=============================================================================
VARIANTE: SI VOUS UTILISEZ UN SEUL CONTRÔLE PERSONNALISÉ
=============================================================================

Si vous avez un contrôle React personnalisé qui gère plusieurs layers,
vous pouvez regrouper les layers ainsi:
-->

<layer id="layerGroup_searches"
       name="Groupes de recherche"
       visible="false"
       type="group">

  <layer id="advancedSearch" ...><!-- Communes --></layer>
  <layer id="gridSearch5x5" ...><!-- Grille 5x5 --></layer>
  <layer id="gridSearch10x10" ...><!-- Grille 10x10 --></layer>

</layer>

<!--
=============================================================================
VARIANTE: MINIMAL (SI VOUS NE VOULEZ QUE LES COMMUNES)
=============================================================================

Si vous ne voulez activer que communeSearch pour le moment:
-->

<extensions>
  <extension type="javascript" src="apps/sinp_hdf/customlayers/SinpBaseLayer.js" />
  <extension type="javascript" src="apps/sinp_hdf/customlayers/communeSearch.js" />
</extensions>

<!-- Dans themes: -->
<layer id="advancedSearch"
       name="Recherche avancée"
       type="customlayer"
       url="apps/sinp_hdf/customlayers/communeSearch.js"
       customcontrol="true"
       customcontrolpath="apps/sinp_hdf/customcontrols/advancedSearch"
       ... />

<!-- Les grilles peuvent être activées ultérieurement -->

